# ===========================
# Database Configuration
# ===========================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# Get this from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# ===========================
# Authentication
# ===========================
# JWT Secret - use a strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_replace_with_random_string

# ===========================
# AI Configuration
# ===========================
# Groq API Key for Llama model access
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ===========================
# Email Configuration
# ===========================
# Gmail app password (not regular password)
# Enable 2FA and generate at: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# ===========================
# Server Configuration
# ===========================
# Server port
PORT=3000

# Environment: development or production
NODE_ENV=development

# Frontend URL (for CORS configuration)
# Development: http://localhost:5173
# Production: https://yourdomain.com
CLIENT_URL=http://localhost:5173
